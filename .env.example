# Email Configuration
# Use this template to create your .env file

# For Gmail, you need an "App Password" (not your regular password)
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create app password for "Mail"
# 4. Use that 16-character password below

EMAIL_FROM=tao.zhang.1977@gmail.com
EMAIL_PASSWORD=your-16-char-app-password-here

# Multiple recipients (comma-separated)
# Add FREE SMS via email-to-SMS gateway!
# Example: YOUR-NUMBER@txt.att.net (AT&T), YOUR-NUMBER@vtext.com (Verizon)
# See FREE_SMS_SETUP.md for your carrier's address
EMAIL_TO=tao.zhang.1977@gmail.com,gao.yuan.77@gmail.com

# SMTP Settings (default for Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# SMS Configuration (Optional - NOT FREE after trial)
# Only enable if you want instant mobile notifications
# Cost: ~$1-2/month after free trial
# Sign up at: https://www.twilio.com/try-twilio
#
# Most users should just use FREE email alerts above!
#
# TWILIO_ACCOUNT_SID=your-account-sid-here
# TWILIO_AUTH_TOKEN=your-auth-token-here
# TWILIO_FROM=+1234567890
# TWILIO_TO=+1234567890

# Alert Settings
ALERT_THRESHOLD=60
